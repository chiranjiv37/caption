# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/captions_studio

# Redis (Celery + Cache)
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 (optional - for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=captions-studio
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=  # For MinIO compatibility

# App Settings
APP_ENV=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload
MAX_UPLOAD_SIZE=500000000  # 500MB in bytes
UPLOAD_CHUNK_SIZE=10485760  # 10MB chunks

# External APIs (for future phases)
OPENAI_API_KEY=
DEEPL_API_KEY=
